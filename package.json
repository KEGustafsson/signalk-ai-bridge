{
  "name": "signalk-ai-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Signal K AI Bridge plugin with embedded webapp panel",
  "type": "module",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-embeddable-webapp"
  ],
  "signalk": {
    "displayName": "AI Bridge",
    "appIcon": "./assets/icons/icon-72x72.svg"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/smoke-test.mjs",
    "test": "rm -rf .tmp-tests && tsc -p tsconfig.test.json && node --experimental-specifier-resolution=node --test .tmp-tests/*.test.js && rm -rf .tmp-tests",
    "check": "npm run lint && npm run typecheck && npm run test",
    "test:smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
